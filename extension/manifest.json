{
  "manifest_version": 3,
  "name": "ProtoConsent",
  "description": "A browser-side consent control panel that enforces your data-use preferences per site and purpose.",
  "version": "0.5.4",

  "icons": {
    "16": "icons/protoconsent_icon_16.png",
    "24": "icons/protoconsent_icon_24.png",
    "32": "icons/protoconsent_icon_32.png",
    "48": "icons/protoconsent_icon_48.png",
    "64": "icons/protoconsent_icon_64.png",
    "128": "icons/protoconsent_icon_128.png",
    "256": "icons/protoconsent_icon_256.png"    
  },

  "action": {
    "default_title": "ProtoConsent",
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/protoconsent_icon_16.png",
      "24": "icons/protoconsent_icon_24.png",
      "32": "icons/protoconsent_icon_32.png",
      "48": "icons/protoconsent_icon_48.png",
      "64": "icons/protoconsent_icon_64.png",
      "128": "icons/protoconsent_icon_128.png",
      "256": "icons/protoconsent_icon_256.png" 
    }
  },

  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "webRequest",
    "webNavigation",
    "unlimitedStorage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/cmp-inject.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/cmp-detect.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/tcf-detect.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],

  "options_page": "pages/purposes-settings.html",

  "declarative_net_request": {
    "rule_resources": [
      { "id": "block_analytics", "enabled": false, "path": "rules/block_analytics.json" },
      { "id": "block_ads", "enabled": false, "path": "rules/block_ads.json" },
      { "id": "block_personalization", "enabled": false, "path": "rules/block_personalization.json" },
      { "id": "block_third_parties", "enabled": false, "path": "rules/block_third_parties.json" },
      { "id": "block_advanced_tracking", "enabled": false, "path": "rules/block_advanced_tracking.json" },
      { "id": "block_analytics_paths", "enabled": false, "path": "rules/block_analytics_paths.json" },
      { "id": "block_ads_paths", "enabled": false, "path": "rules/block_ads_paths.json" },
      { "id": "block_personalization_paths", "enabled": false, "path": "rules/block_personalization_paths.json" },
      { "id": "block_third_parties_paths", "enabled": false, "path": "rules/block_third_parties_paths.json" },
      { "id": "block_advanced_tracking_paths", "enabled": false, "path": "rules/block_advanced_tracking_paths.json" },
      { "id": "strip_tracking_params", "enabled": false, "path": "rules/strip_tracking_params.json" },
      { "id": "strip_tracking_params_sites", "enabled": false, "path": "rules/strip_tracking_params_sites.json" }
    ]
  }
}
